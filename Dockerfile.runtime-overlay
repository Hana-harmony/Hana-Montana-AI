ARG BASE_IMAGE
FROM ${BASE_IMAGE}

USER root

COPY pyproject.toml uv.lock ./
COPY src ./src

RUN uv sync --frozen --no-dev --extra transformer \
    && find /app/src -type f \( -name '*.joblib' -o -name '*.safetensors' \) -exec chmod 0444 {} + \
    && chmod -R a+rX,go-w /app/src

ENV TOKENIZERS_PARALLELISM=false \
    OMP_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    NUMEXPR_NUM_THREADS=1

USER 65532:65532
